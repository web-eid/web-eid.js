{
  "name": "@web-eid/web-eid-library",
  "version": "2.1.0-beta.1",
  "description": "",
  "scripts": {
    "lint": "eslint",
    "build": "npm run clean && npm run compile && npm run bundle",
    "clean": "rimraf ./dist",
    "compile": "tsc",
    "bundle": "rollup -c",
    "test": "jest -i --silent --verbose",
    "prepack": "npm run test",
    "prepare": "npm run build && cp -R ./dist/node/* ./",
    "postpack": "rimraf --glob ./web-eid.js ./config.js ./errors ./models ./services ./utils ./*.d.ts ./*.map"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/web-eid/web-eid.js.git"
  },
  "type": "module",
  "main": "dist/es/web-eid.js",
  "exports": {
    ".": {
      "import": {
        "types": "./web-eid.d.ts",
        "default": "./dist/es/web-eid.js"
      }
    },
    "./web-eid": {
      "import": {
        "types": "./web-eid.d.ts",
        "default": "./dist/es/web-eid.js"
      }
    },
    "./models": {
      "import": {
        "types": "./models/index.d.ts",
        "default": "./models/index.js"
      }
    },
    "./models/ActionOptions": {
      "import": {
        "types": "./models/ActionOptions.d.ts",
        "default": "./models/ActionOptions.js"
      }
    },
    "./models/message/LibraryResponse": {
      "import": {
        "types": "./models/message/LibraryResponse.d.ts",
        "default": "./models/message/LibraryResponse.js"
      }
    }
  },
  "files": [
    "config.d.ts",
    "config.d.ts.map",
    "config.js",
    "config.js.map",
    "web-eid.d.ts",
    "web-eid.d.ts.map",
    "web-eid.js",
    "web-eid.js.map",
    "errors/**/*",
    "models/**/*",
    "services/**/*",
    "utils/**/*",
    "dist/es/*",
    "dist/iife/*",
    "dist/umd/*",
    "src/*.ts",
    "src/errors/**/*",
    "src/models/**/*",
    "src/services/**/*",
    "src/utils/**/*"
  ],
  "types": "web-eid.d.ts",
  "author": "Tanel Metsar",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/jest": "^29.5.14",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^6.1.2",
    "rollup": "^4.57.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-license": "^3.6.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
